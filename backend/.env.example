APP_NAME=Shaturne
APP_ENV=local
APP_KEY=
APP_DEBUG=true          # WAJIB false di staging & production (§10.11)
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=shaturne
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false           # WAJIB true di production
SESSION_PATH=/
SESSION_DOMAIN=null             # WAJIB diisi di production, misal: .shaturne.dev
SESSION_SECURE_COOKIE=false     # WAJIB true di production (cookie HTTPS-only)
# SESSION_SAME_SITE=lax         # Ganti ke "none" kalau FE & BE beda root domain (wajib HTTPS)

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@shaturne.dev"
MAIL_FROM_NAME="Shaturne"
MAIL_OWNER_ADDRESS="rathermyself08@gmail.com"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Spotify "now playing" (optional). Leave empty → endpoint reports offline.
# Obtain a user-scoped refresh token (scope: user-read-currently-playing).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# GitHub Contributions heatmap (optional). Leave empty → heatmap disabled.
# Scope required: read:user (public repos only — do NOT grant write or repo:private).
# Generate at github.com/settings/tokens (classic) or fine-grained token.
GITHUB_PAT=
GITHUB_USERNAME=
